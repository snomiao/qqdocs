{
  "name": "qqdocs",
  "version": "1.2.0",
  "description": "Tencent Docs (docs.qq.com) CLI and library — thin MCP JSON-RPC client.",
  "keywords": [
    "tencent-docs",
    "docs.qq.com",
    "qq",
    "cli",
    "mcp"
  ],
  "homepage": "https://github.com/snomiao/qqdocs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snomiao/qqdocs.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "qqdoc": "./bin/qqdocs.ts",
    "qqdocs": "./bin/qqdocs.ts"
  },
  "files": [
    "src/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@types/yargs": "^17.0.35",
    "semantic-release": "^24.2.0",
    "typescript": "^5.6.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
